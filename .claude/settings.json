{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [{"type": "command", "command": ".claude/hooks/enforce-fix-findings.sh"}]
      },
      {
        "matcher": "Agent|Bash",
        "hooks": [{"type": "command", "command": ".claude/hooks/enforce-corrections.sh"}]
      },
      {
        "matcher": "mcp__linear-server__linear_",
        "hooks": [{"type": "command", "command": ".claude/hooks/block-linear-mcp-writes.sh"}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": ".claude/hooks/security-review-precommit.sh"}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {"type": "command", "command": ".claude/hooks/check-python-imports.sh"},
          {"type": "command", "command": ".claude/hooks/god-class-check.sh"}
        ]
      }
    ],
    "TeammateIdle": [
      {"hooks": [{"type": "command", "command": ".claude/hooks/redirect-idle-teammate.sh"}]}
    ],
    "TaskCompleted": [
      {"hooks": [{"type": "command", "command": ".claude/hooks/validate-task-completion.sh"}]}
    ],
    "Stop": [
      {
        "hooks": [
          {"type": "command", "command": ".claude/hooks/check-dismissive-language.sh"},
          {"type": "command", "command": ".claude/hooks/challenge-handoff.sh"},
          {"type": "command", "command": ".claude/hooks/challenge-scope-creep-dismissal.sh"}
        ]
      }
    ]
  },
  "mcpServers": {
    "schema-mcp": {
      "command": ".venv/bin/python",
      "args": ["-m", "schema_mcp.server"],
      "env": {"SCHEMAS_DIR": "./schemas"}
    }
  }
}
